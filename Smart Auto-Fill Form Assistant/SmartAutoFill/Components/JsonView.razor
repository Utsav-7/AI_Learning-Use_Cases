@using System.Text.Json.Nodes
@using System.Text.RegularExpressions

@if (Node is JsonObject obj)
{
    <div class="jv-object">
        @foreach (var kv in obj)
        {
            <div class="jv-field">
                <div class="jv-key">@Humanize(kv.Key)</div>
                <div class="jv-val">
                    <JsonView Node="kv.Value" />
                </div>
            </div>
        }
    </div>
}
else if (Node is JsonArray arr)
{
    @if (arr.Count == 0)
    {
        <span class="jv-null">—</span>
    }
    else if (IsScalarArray(arr))
    {
        <div class="jv-chips">
            @foreach (var item in arr)
            {
                <span class="jv-chip">@Display(item)</span>
            }
        </div>
    }
    else
    {
        <div class="jv-cards">
            @foreach (var item in arr)
            {
                <div class="jv-card">
                    <JsonView Node="item" />
                </div>
            }
        </div>
    }
}
else
{
    @if (Node is null || string.IsNullOrWhiteSpace(Display(Node)))
    {
        <span class="jv-null">—</span>
    }
    else
    {
        <span class="jv-scalar">@Display(Node)</span>
    }
}

@code {
    [Parameter] public JsonNode? Node { get; set; }

    private static bool IsScalarArray(JsonArray arr) => arr.All(x => x is null || x is JsonValue);

    private static string Display(JsonNode? n) => n?.ToString() ?? "";

    private static string Humanize(string key)
    {
        if (string.IsNullOrEmpty(key)) return key;
        var spaced = Regex.Replace(key, "([a-z0-9])([A-Z])", "$1 $2");
        return char.ToUpperInvariant(spaced[0]) + spaced[1..];
    }
}
