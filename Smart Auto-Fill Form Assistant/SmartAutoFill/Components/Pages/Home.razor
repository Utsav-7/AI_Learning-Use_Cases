@page "/"
@rendermode InteractiveServer
@using System.Text.Json
@using System.Text.Json.Nodes
@using System.Text.RegularExpressions
@inject IDocumentExtractionService Extractor
@inject IMaskingService Masking
@inject ILlmProvider Llm
@inject ILogger<Home> Logger

<PageTitle>Smart Auto-Fill Form Assistant</PageTitle>

<div class="page-wrap">
    <header class="hero">
        <h1>Smart Auto-Fill Form Assistant</h1>
        <p>Upload a document (PDF or image) and get the extracted data as JSON.</p>
    </header>

    <section class="card">
        <div class="upload-row">
            <label class="file-label">
                Choose file
                <InputFile OnChange="OnFileSelected" accept=".pdf,.png,.jpg,.jpeg,.tiff,.bmp" disabled="@_busy" />
            </label>

            <button class="btn-primary" @onclick="Analyze" disabled="@(_busy || _file is null)">
                @(_busy ? "Processing…" : "Upload")
            </button>
        </div>
        @if (_file is not null)
        {
            <p class="file-name">Selected: <strong>@_file.Name</strong> (@(_file.Size / 1024) KB)</p>
        }
        @if (!string.IsNullOrEmpty(_error))
        {
            <p class="error">@_error</p>
        }
    </section>

    @if (!string.IsNullOrEmpty(_json) || !string.IsNullOrEmpty(_previewDataUrl))
    {
        <div class="result-grid">
            @if (!string.IsNullOrEmpty(_previewDataUrl))
            {
                <section class="card">
                    <h2>Uploaded Document</h2>
                    <div class="preview">
                        @if (_isImage)
                        {
                            <img src="@_previewDataUrl" alt="Uploaded document" />
                        }
                        else
                        {
                            <iframe src="@_previewDataUrl" title="Uploaded document"></iframe>
                        }
                    </div>
                </section>
            }

            @if (!string.IsNullOrEmpty(_json))
            {
                <section class="card">
                    <h2>JSON</h2>
                    <pre class="json">@_json</pre>
                </section>
            }
        </div>
    }
</div>

@code {
    // OCR with the universal layout model; the LLM auto-detects the document type.
    private const string OcrCategory = "General Document (Layout)";

    private IBrowserFile? _file;
    private bool _busy;
    private string? _error;
    private string? _json;
    private string? _previewDataUrl;
    private bool _isImage;

    private const long MaxBytes = 20 * 1024 * 1024; // 20 MB

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        ResetState();
        _file = e.File;
    }

    private void ResetState()
    {
        _error = null;
        _json = null;
        _previewDataUrl = null;
        _isImage = false;
    }

    private async Task Analyze()
    {
        if (_file is null) return;
        _busy = true;
        ResetState();

        try
        {
            // Read the file once; reuse the bytes for extraction and for the preview.
            byte[] bytes;
            await using (var stream = _file.OpenReadStream(MaxBytes))
            using (var ms = new MemoryStream())
            {
                await stream.CopyToAsync(ms);
                bytes = ms.ToArray();
            }

            // Document preview (image inline, PDF in an iframe).
            var contentType = string.IsNullOrWhiteSpace(_file.ContentType)
                ? GuessContentType(_file.Name)
                : _file.ContentType;
            _isImage = contentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase);
            _previewDataUrl = $"data:{contentType};base64,{Convert.ToBase64String(bytes)}";

            // OCR with the universal layout model (works for any document).
            using var extractStream = new MemoryStream(bytes);
            var result = await Extractor.ExtractAsync(extractStream, _file.Name, OcrCategory);

            // Mask PII before anything reaches the LLM.
            var mask = Masking.Mask(result.RawText);

            // Ollama auto-detects the document type and extracts the nested JSON.
            var structuredMasked = await Llm.ClassifyAndExtractAsync(mask.MaskedText, JsonTemplates.AutoInstruction());
            var structuredJson = structuredMasked is null ? null : Masking.Unmask(structuredMasked, mask.Map);

            _json = BuildJson(structuredJson, result);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Processing failed");
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private static readonly JsonSerializerOptions JsonOut = new()
    {
        WriteIndented = true,
        Encoder = System.Text.Encodings.Web.JavaScriptEncoder.UnsafeRelaxedJsonEscaping
    };

    /// <summary>
    /// Pretty-print the LLM's auto-detected nested JSON. If the LLM was unavailable or
    /// returned invalid JSON, fall back to the raw OCR key-value pairs so nothing is lost.
    /// </summary>
    private static string BuildJson(string? llmJson, ExtractionResult result)
    {
        if (!string.IsNullOrWhiteSpace(llmJson))
        {
            try
            {
                var node = JsonNode.Parse(llmJson);
                if (node is not null)
                {
                    // The model often can't map masked placeholders ({{EMAIL_1}}) back to a field,
                    // so fill contact fields deterministically from the original OCR text.
                    FillContactFields(node, result.RawText);
                    return node.ToJsonString(JsonOut);
                }
            }
            catch { /* fall through to the OCR fallback */ }
        }

        // Fallback (AI model unavailable): emit whatever OCR detected, with Azure's confidence.
        var fallback = new JsonObject
        {
            ["documentType"] = "unknown",
            ["data"] = new JsonObject
            {
                ["fields"] = new JsonArray(result.Fields
                    .Where(f => !string.IsNullOrWhiteSpace(f.Value))
                    .Select(f => (JsonNode)new JsonObject
                    {
                        ["label"] = f.DisplayName,
                        ["value"] = f.Value
                    }).ToArray())
            }
        };
        return fallback.ToJsonString(JsonOut);
    }

    /// <summary>
    /// Walk the result JSON and fill any null email/phone/linkedIn field using regex over the
    /// original OCR text. These have reliable patterns, so we don't depend on the LLM
    /// (which often drops masked placeholders).
    /// </summary>
    private static void FillContactFields(JsonNode node, string rawText)
    {
        var email = Regex.Match(rawText, @"[A-Za-z0-9._%+\-]+@[A-Za-z0-9.\-]+\.[A-Za-z]{2,}").Value;
        var linkedIn = Regex.Match(rawText, @"(?:https?:\/\/)?(?:www\.)?linkedin\.com\/[^\s]+", RegexOptions.IgnoreCase).Value;
        var phone = Regex.Match(rawText, @"(?:\+?\d{1,3}[\s\-]?)?(?:\d[\s\-\.]?){10}").Value.Trim();

        Walk(node);

        void Walk(JsonNode? n)
        {
            switch (n)
            {
                case JsonObject obj:
                    foreach (var kv in obj.ToList())
                    {
                        if (kv.Value is null)
                        {
                            var fill = kv.Key.ToLowerInvariant() switch
                            {
                                "email" => email,
                                "phone" => phone,
                                "linkedin" => linkedIn,
                                _ => null
                            };
                            if (!string.IsNullOrWhiteSpace(fill))
                            {
                                obj[kv.Key] = fill;
                                continue;
                            }
                        }
                        Walk(kv.Value);
                    }
                    break;
                case JsonArray arr:
                    foreach (var item in arr) Walk(item);
                    break;
            }
        }
    }

    private static string GuessContentType(string fileName) =>
        Path.GetExtension(fileName).ToLowerInvariant() switch
        {
            ".pdf" => "application/pdf",
            ".png" => "image/png",
            ".jpg" or ".jpeg" => "image/jpeg",
            ".tiff" or ".tif" => "image/tiff",
            ".bmp" => "image/bmp",
            _ => "application/octet-stream"
        };
}
