@page "/"
@rendermode InteractiveServer
@using System.Text.Json
@using System.Text.Json.Nodes
@using System.Text.RegularExpressions
@inject IDocumentExtractionService Extractor
@inject IMaskingService Masking
@inject ILlmProviderFactory LlmProviders
@inject IResultValidator Validator
@inject IJSRuntime JS
@inject ILogger<Home> Logger

<PageTitle>Smart Auto-Fill Form Assistant</PageTitle>

<div class="page-wrap">
    <header class="hero">
        <h1>Smart Auto-Fill Form Assistant</h1>
        <p>Upload a document (PDF or image) and get the extracted data as JSON.</p>
    </header>

    @if (_toast is not null)
    {
        <div class="toast toast-@_toast.Kind">
            <span>@_toast.Message</span>
            <button class="toast-close" @onclick="() => _toast = null">×</button>
        </div>
    }

    @if (_busy)
    {
        <div class="loading-overlay">
            <div class="spinner"></div>
            <div class="loading-text">Processing with @_provider…</div>
            <div class="loading-sub">Extracting text and analysing the document — this can take a moment.</div>
        </div>
    }

    <section class="card">
        <div class="upload-row">
            <label>
                AI model
                <select @bind="_provider" disabled="@_busy">
                    @foreach (var p in LlmProviders.AvailableProviders)
                    {
                        <option value="@p">@p</option>
                    }
                </select>
            </label>

            <label class="file-label">
                Choose file
                <InputFile OnChange="OnFileSelected" accept=".pdf,.png,.jpg,.jpeg,.tiff,.bmp" disabled="@_busy" />
            </label>

            <button class="btn-primary" @onclick="Analyze" disabled="@(_busy || _file is null)">
                @(_busy ? "Processing…" : "Upload")
            </button>
        </div>
        @if (_file is not null)
        {
            <p class="file-name">Selected: <strong>@_file.Name</strong> (@(_file.Size / 1024) KB)</p>
        }
        @if (!string.IsNullOrEmpty(_error))
        {
            <p class="error">@_error</p>
        }
    </section>

    @if (!string.IsNullOrEmpty(_json) || !string.IsNullOrEmpty(_previewDataUrl))
    {
        <div class="result-grid">
            @if (!string.IsNullOrEmpty(_previewDataUrl))
            {
                <section class="card preview-card">
                    <h2>Uploaded Document</h2>
                    @if (_isImage)
                    {
                        <div class="zoom-container" title="Hover to zoom">
                            <img src="@_previewDataUrl" alt="Uploaded document" />
                        </div>
                        <p class="hint">
                            <svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                <circle cx="11" cy="11" r="7" /><line x1="21" y1="21" x2="16.65" y2="16.65" />
                            </svg>
                            Hover over the image to zoom.
                        </p>
                    }
                    else
                    {
                        <div class="preview">
                            <iframe class="pdf-frame" src="@_previewDataUrl" title="Uploaded document"></iframe>
                        </div>
                    }
                </section>
            }

            @if (!string.IsNullOrEmpty(_json))
            {
                <section class="card json-card">
                    <div class="json-toolbar">
                        <h2>JSON</h2>
                        <button class="btn-ghost" @onclick="CopyJson">@_copyLabel</button>
                    </div>

                    @if (_issues.Count > 0)
                    {
                        <div class="review">
                            <div class="review-title">
                                <svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M12 3 L22 20 H2 Z" /><line x1="12" y1="10" x2="12" y2="14" /><circle cx="12" cy="17.5" r=".6" fill="currentColor" />
                                </svg>
                                @_issues.Count field(s) need review
                            </div>
                            <ul>
                                @foreach (var issue in _issues)
                                {
                                    <li class="review-@issue.Severity">
                                        <strong>@issue.Field</strong> — @issue.Message
                                    </li>
                                }
                            </ul>
                        </div>
                    }

                    <pre class="json">@HighlightJson(_json)</pre>
                </section>
            }
        </div>
    }
</div>

@code {
    // OCR with the universal layout model; the LLM auto-detects the document type.
    private const string OcrCategory = "General Document (Layout)";

    private IBrowserFile? _file;
    private bool _busy;
    private string? _error;
    private string? _json;
    private IReadOnlyList<FieldIssue> _issues = Array.Empty<FieldIssue>();
    private string? _previewDataUrl;
    private bool _isImage;
    private string _provider = "";
    private Toast? _toast;
    private string _copyLabel = "Copy";

    private const long MaxBytes = 20 * 1024 * 1024; // 20 MB

    protected override void OnInitialized() => _provider = LlmProviders.DefaultProvider;

    private record Toast(string Message, string Kind); // Kind: success | warning | error

    private void ShowToast(string message, string kind)
    {
        _toast = new Toast(message, kind);
        // Auto-dismiss after 6 seconds.
        _ = Task.Run(async () =>
        {
            await Task.Delay(6000);
            _toast = null;
            await InvokeAsync(StateHasChanged);
        });
    }

    private static readonly string[] AllowedExtensions =
        { ".pdf", ".png", ".jpg", ".jpeg", ".tiff", ".tif", ".bmp" };

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        ResetState();
        _toast = null;

        var file = e.File;
        var ext = Path.GetExtension(file.Name).ToLowerInvariant();
        if (!AllowedExtensions.Contains(ext))
        {
            _file = null;
            ShowToast($"Unsupported file type \"{ext}\". Please upload a PDF or image (PNG, JPG, TIFF, BMP).", "error");
            return;
        }
        if (file.Size <= 0)
        {
            _file = null;
            ShowToast("The selected file is empty (0 bytes).", "error");
            return;
        }

        _file = file;
    }

    /// <summary>Verify the bytes actually match a PDF/image signature (catches renamed files).</summary>
    private static bool IsAllowedContent(byte[] b)
    {
        if (b.Length < 4) return false;
        bool Starts(params byte[] sig) => b.Length >= sig.Length && b.Take(sig.Length).SequenceEqual(sig);
        return Starts(0x25, 0x50, 0x44, 0x46)        // %PDF
            || Starts(0x89, 0x50, 0x4E, 0x47)        // PNG
            || Starts(0xFF, 0xD8, 0xFF)              // JPEG
            || Starts(0x42, 0x4D)                    // BMP
            || Starts(0x49, 0x49, 0x2A, 0x00)        // TIFF (little-endian)
            || Starts(0x4D, 0x4D, 0x00, 0x2A);       // TIFF (big-endian)
    }

    private void ResetState()
    {
        _error = null;
        _json = null;
        _issues = Array.Empty<FieldIssue>();
        _previewDataUrl = null;
        _isImage = false;
    }

    private async Task Analyze()
    {
        if (_file is null) return;
        _busy = true;
        ResetState();
        await Task.Yield(); // let the loading overlay render before the heavy work

        try
        {
            // Read the file once; reuse the bytes for extraction and for the preview.
            byte[] bytes;
            await using (var stream = _file.OpenReadStream(MaxBytes))
            using (var ms = new MemoryStream())
            {
                await stream.CopyToAsync(ms);
                bytes = ms.ToArray();
            }

            // Validate: non-empty and a real PDF/image (guards against renamed/corrupt files).
            if (bytes.Length == 0)
            {
                ShowToast("The file is empty — nothing to process.", "error");
                return;
            }
            if (!IsAllowedContent(bytes))
            {
                ShowToast("This file isn't a valid PDF or image. Please upload a genuine PDF/PNG/JPG/TIFF/BMP.", "error");
                return;
            }

            // Document preview (image inline, PDF in an iframe).
            var contentType = string.IsNullOrWhiteSpace(_file.ContentType)
                ? GuessContentType(_file.Name)
                : _file.ContentType;
            _isImage = contentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase);
            _previewDataUrl = $"data:{contentType};base64,{Convert.ToBase64String(bytes)}";

            // OCR with the universal layout model (works for any document).
            using var extractStream = new MemoryStream(bytes);
            var result = await Extractor.ExtractAsync(extractStream, _file.Name, OcrCategory);

            // Mask PII before anything reaches the LLM.
            var mask = Masking.Mask(result.RawText);

            // Selected AI model auto-detects the document type and extracts the nested JSON.
            var provider = LlmProviders.Get(_provider);
            var llm = await provider.ClassifyAndExtractAsync(mask.MaskedText, JsonTemplates.AutoInstruction());
            var structuredJson = llm.Json is null ? null : Masking.Unmask(llm.Json, mask.Map);

            _json = BuildJson(structuredJson, result);

            // Validate the extracted data (formats, cross-field, low confidence).
            _issues = Validator.Validate(_json, result.RawText);

            // Toast: warning if the model failed (OCR fallback) or some fields need review; else success.
            if (llm.Error is not null)
                ShowToast($"{provider.Name}: {llm.Error} Showing OCR fallback.", "warning");
            else if (_issues.Count > 0)
                ShowToast($"Extracted with {provider.Name}. {_issues.Count} field(s) need review.", "warning");
            else
                ShowToast($"Extracted successfully with {provider.Name}.", "success");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Processing failed");
            _error = ex.Message;
            ShowToast($"Processing failed: {ex.Message}", "error");
        }
        finally
        {
            _busy = false;
        }
    }

    private static readonly JsonSerializerOptions JsonOut = new()
    {
        WriteIndented = true,
        Encoder = System.Text.Encodings.Web.JavaScriptEncoder.UnsafeRelaxedJsonEscaping
    };

    /// <summary>
    /// Pretty-print the LLM's auto-detected nested JSON. If the LLM was unavailable or
    /// returned invalid JSON, fall back to the raw OCR key-value pairs so nothing is lost.
    /// </summary>
    private static string BuildJson(string? llmJson, ExtractionResult result)
    {
        if (!string.IsNullOrWhiteSpace(llmJson))
        {
            try
            {
                var node = JsonNode.Parse(llmJson);
                if (node is not null)
                {
                    // The model often can't map masked placeholders ({{EMAIL_1}}) back to a field,
                    // so fill contact fields deterministically from the original OCR text.
                    FillContactFields(node, result.RawText);
                    return node.ToJsonString(JsonOut);
                }
            }
            catch { /* fall through to the OCR fallback */ }
        }

        // Fallback (AI model unavailable): emit whatever OCR detected, with Azure's confidence.
        var fallback = new JsonObject
        {
            ["documentType"] = "unknown",
            ["data"] = new JsonObject
            {
                ["fields"] = new JsonArray(result.Fields
                    .Where(f => !string.IsNullOrWhiteSpace(f.Value))
                    .Select(f => (JsonNode)new JsonObject
                    {
                        ["label"] = f.DisplayName,
                        ["value"] = f.Value
                    }).ToArray())
            }
        };
        return fallback.ToJsonString(JsonOut);
    }

    /// <summary>
    /// Walk the result JSON and fill any null email/phone/linkedIn field using regex over the
    /// original OCR text. These have reliable patterns, so we don't depend on the LLM
    /// (which often drops masked placeholders).
    /// </summary>
    private static void FillContactFields(JsonNode node, string rawText)
    {
        var email = Regex.Match(rawText, @"[A-Za-z0-9._%+\-]+@[A-Za-z0-9.\-]+\.[A-Za-z]{2,}").Value;
        var linkedIn = Regex.Match(rawText, @"(?:https?:\/\/)?(?:www\.)?linkedin\.com\/[^\s]+", RegexOptions.IgnoreCase).Value;
        var phone = Regex.Match(rawText, @"(?:\+?\d{1,3}[\s\-]?)?(?:\d[\s\-\.]?){10}").Value.Trim();

        Walk(node);

        void Walk(JsonNode? n)
        {
            switch (n)
            {
                case JsonObject obj:
                    foreach (var kv in obj.ToList())
                    {
                        if (kv.Value is null)
                        {
                            var fill = kv.Key.ToLowerInvariant() switch
                            {
                                "email" => email,
                                "phone" => phone,
                                "linkedin" => linkedIn,
                                _ => null
                            };
                            if (!string.IsNullOrWhiteSpace(fill))
                            {
                                obj[kv.Key] = fill;
                                continue;
                            }
                        }
                        Walk(kv.Value);
                    }
                    break;
                case JsonArray arr:
                    foreach (var item in arr) Walk(item);
                    break;
            }
        }
    }

    private static string GuessContentType(string fileName) =>
        Path.GetExtension(fileName).ToLowerInvariant() switch
        {
            ".pdf" => "application/pdf",
            ".png" => "image/png",
            ".jpg" or ".jpeg" => "image/jpeg",
            ".tiff" or ".tif" => "image/tiff",
            ".bmp" => "image/bmp",
            _ => "application/octet-stream"
        };

    private async Task CopyJson()
    {
        if (string.IsNullOrEmpty(_json)) return;
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _json);
            _copyLabel = "Copied";
            StateHasChanged();
            await Task.Delay(1500);
            _copyLabel = "Copy";
            StateHasChanged();
        }
        catch (Exception ex) { Logger.LogWarning(ex, "Clipboard copy failed"); }
    }

    private static readonly Regex JsonToken = new(
        "\"(?:\\\\.|[^\"\\\\])*\"(?:\\s*:)?|\\b(?:true|false|null)\\b|-?\\d+(?:\\.\\d+)?(?:[eE][+\\-]?\\d+)?",
        RegexOptions.Compiled);

    /// <summary>Lightweight JSON syntax highlighting → colored spans.</summary>
    private static MarkupString HighlightJson(string json)
    {
        var sb = new System.Text.StringBuilder();
        var last = 0;
        foreach (Match m in JsonToken.Matches(json))
        {
            sb.Append(Enc(json.Substring(last, m.Index - last)));
            var tok = m.Value;
            string cls;
            if (tok.StartsWith("\""))
                cls = tok.TrimEnd().EndsWith(":") ? "j-key" : "j-str";
            else if (tok is "true" or "false" or "null")
                cls = "j-kw";
            else
                cls = "j-num";
            sb.Append($"<span class=\"{cls}\">{Enc(tok)}</span>");
            last = m.Index + m.Length;
        }
        sb.Append(Enc(json[last..]));
        return (MarkupString)sb.ToString();

        static string Enc(string s) => System.Net.WebUtility.HtmlEncode(s);
    }
}
